 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 02 — Label Analysis\n",
    "\n",
    "Run after `generate_labels.py` to validate label quality.\n",
    "\n",
    "Goals:\n",
    "- Visualise class distribution\n",
    "- Check congestion score distribution\n",
    "- Identify if thresholds need tuning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "from src.config.settings import CFG, PROJECT_ROOT\n",
    "\n",
    "labels_path = PROJECT_ROOT / CFG['labeling']['output_csv']\n",
    "df = pd.read_csv(labels_path)\n",
    "print(f'Loaded {len(df)} windows')\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Class distribution\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "\n",
    "df['label'].value_counts().plot(kind='bar', ax=axes[0], color=['green','orange','red'])\n",
    "axes[0].set_title('Label distribution (count)')\n",
    "axes[0].set_xlabel('Congestion level')\n",
    "\n",
    "df['label'].value_counts(normalize=True).plot(kind='pie', ax=axes[1], autopct='%1.1f%%',\n",
    "                                               colors=['green','orange','red'])\n",
    "axes[1].set_title('Label distribution (%)')\n",
    "axes[1].set_ylabel('')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Congestion score distribution\n",
    "plt.figure(figsize=(8, 4))\n",
    "sns.histplot(df['congestion_score'], bins=40, kde=True)\n",
    "cfg_thresholds = CFG['labeling']['score_thresholds']\n",
    "plt.axvline(cfg_thresholds['low_max'], color='green', linestyle='--', label=f\"low_max={cfg_thresholds['low_max']}\")\n",
    "plt.axvline(cfg_thresholds['high_min'], color='red', linestyle='--', label=f\"high_min={cfg_thresholds['high_min']}\")\n",
    "plt.title('Congestion score distribution')\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print('If distribution is skewed, adjust score_thresholds in config.yaml')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Feature distributions per class\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 4))\n",
    "for ax, col in zip(axes, ['vehicle_count', 'avg_speed', 'stop_fraction']):\n",
    "    if col in df.columns:\n",
    "        for lbl, color in zip(['low','medium','high'],['green','orange','red']):\n",
    "            subset = df[df['label']==lbl][col].dropna()\n",
    "            sns.kdeplot(subset, ax=ax, label=lbl, color=color)\n",
    "        ax.set_title(col)\n",
    "        ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
 ],
